# MatrixTrade (trading dashboard, /trades, /connect)
# Required — login fails if missing
MATRIXTRADE_PASSWORD=change-me-trading

# Health Vault (/health — separate login)
# Required — login fails if missing
HEALTH_VAULT_PASSWORD=change-me-health

# PIN for secret records (optional second lock; hv-secret cookie uses HMAC of this value)
HEALTH_VAULT_SECRET=change-me-secret-pin
