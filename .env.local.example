# Copy to .env.local and set your own values:
#   copy .env.local.example .env.local

# ── MatrixTrade (trading) ─────────────────────────────────────────────
# Protects: /  /trades  /connect
# Login page: /login
MATRIXTRADE_PASSWORD=change-me-trading

# ── ARGUS (professional journal) ──────────────────────────────────────
# Protects: /argus/*
# Login page: /argus/login
ARGUS_PASSWORD=change-me-argus

# Optional — name shown as "Delivered by …" on exported HTML/Markdown reports (default: devinit)
ARGUS_DELIVER_PREPARER=devinit

# Optional — force watermark on exports during testing (default: off). Future: free tier on, premium off.
# ARGUS_DELIVER_WATERMARK=1


# ── ARGUS Rule 0 — durable journal (required on Vercel) ───────────────
# ARGUS_JOURNAL_STORE=json          # local default — journal.json on disk
# ARGUS_JOURNAL_STORE=supabase      # production — run supabase/argus-journal.sql once
# ARGUS_ALLOW_DESTRUCTIVE=1         # allow Clear all on local JSON only (blocked when Supabase enabled)
# ARGUS_TESTING_UI=1                # show Clear all button in dev
# Run supabase/argus-protection.sql after inbox+journal SQL for soft delete, RLS, hard-delete blocks

# ── ARGUS inbox (cloud-first on Vercel) ───────────────────────────────
# ARGUS_INBOX_STORE=json          # local default — filesystem journal.json
# ARGUS_INBOX_STORE=supabase      # production — Supabase inbox + Storage
# Run supabase/argus-inbox.sql once in Supabase before enabling supabase mode.

# Write-only inbox API — Bearer or X-Argus-Inbox-Token header
# POST /api/argus/inbox          — generic intake (JSON or multipart)
# POST /api/argus/email-inbox    — structured email JSON intake (Bearer only)
ARGUS_INBOX_TOKEN=change-me-inbox-token

# Persistent data root — any folder path (NO extra disk required)
# Recommended: a folder in your user profile, outside the repo
# Windows: ARGUS_DATA_DIR=C:\Users\vmartinez9\ArgusData
# Or:      ARGUS_DATA_DIR=%USERPROFILE%\ArgusData
# If unset, falls back to {repo}/data/argus (legacy, still gitignored)
# ARGUS_DATA_DIR=C:\Users\vmartinez9\ArgusData

# Write-only inbox API — Bearer or X-Matrixtrade-Inbox-Token
# POST /api/trading/inbox  — local proposals (LAN / ChatGPT Actions)
MATRIXTRADE_INBOX_TOKEN=change-me-trading-inbox

# Cloudflare Worker bridge (same tokens as bridge/.dev.vars)
# BRIDGE_WORKER_URL=https://matrixtrade-bridge.argometal.workers.dev
# BRIDGE_WRITE_TOKEN=change-me-write
# BRIDGE_READ_TOKEN=change-me-read

# ── Supabase (cloud-first trading data) ───────────────────────────────
# TRADES_STORE=json          # local default — uses data/trades.json
# TRADES_STORE=supabase      # production — Supabase is source of truth
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# OBSIDIAN_SYNC=false        # optional — disable local Obsidian writes

# Public app URL (optional — was used for disabled AI Session QR; safe to omit)
# NEXT_PUBLIC_APP_URL=https://matrix-trade-theta.vercel.app

# ── Vercel: add the same three names under Project → Environment Variables
# (Production). Redeploy after saving.

# Legacy names (still work locally if you have old .env.local):
# HEALTH_VAULT_PASSWORD  →  use ARGUS_PASSWORD instead
# HEALTH_VAULT_SECRET    →  use ARGUS_PRIVATE_PIN instead
