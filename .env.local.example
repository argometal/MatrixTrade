# Copy to .env.local and set your own values:
#   copy .env.local.example .env.local

# ── MatrixTrade (trading) ─────────────────────────────────────────────
# Protects: /  /trades  /connect
# Login page: /login
MATRIXTRADE_PASSWORD=change-me-trading

# ── ARGUS (professional journal) ──────────────────────────────────────
# Protects: /argus/*
# Login page: /argus/login
ARGUS_PASSWORD=change-me-argus

# Optional — hides/shows private logs inside ARGUS
ARGUS_PRIVATE_PIN=change-me-private-pin

# Write-only inbox API (POST /api/argus/inbox) — Bearer or X-Argus-Inbox-Token header
ARGUS_INBOX_TOKEN=change-me-inbox-token

# ── Vercel: add the same three names under Project → Environment Variables
# (Production). Redeploy after saving.

# Legacy names (still work locally if you have old .env.local):
# HEALTH_VAULT_PASSWORD  →  use ARGUS_PASSWORD instead
# HEALTH_VAULT_SECRET    →  use ARGUS_PRIVATE_PIN instead
