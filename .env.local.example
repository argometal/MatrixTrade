# MatrixTrade (trading dashboard, /trades, /connect)
# Required — login fails if missing
MATRIXTRADE_PASSWORD=change-me-trading

# Health Vault (/health — Authenticator TOTP, single user Vic)
# Required — base32 secret from your Authenticator app (fail closed if missing)
HEALTH_VAULT_TOTP_SECRET=

# Recovery emails (placeholder — email sending not implemented)
HEALTH_VAULT_RECOVERY_EMAIL_PRIMARY=argometal@hotmail.com
HEALTH_VAULT_RECOVERY_EMAIL_SECONDARY=argometal@gmail.com

# Optional PIN for secret records (alternative to re-entering TOTP for hv-secret unlock)
HEALTH_VAULT_SECRET=
