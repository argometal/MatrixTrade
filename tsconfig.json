{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "bridge", "argus-email-bridge", "tools/validate-argus-capture.ts", "tools/simulate-email-worker-intake.ts", "tools/validate-supabase-trades.ts", "tools/validate-argus-phase0-crud.ts", "tools/validate-argus-production-acceptance.ts", "tools/validate-argus-production-workflows.ts", "tools/validate-argus-link-workflow.ts", "tools/verify-supabase-schema.ts", "tools/test-scout-repair-path.ts"]
}
